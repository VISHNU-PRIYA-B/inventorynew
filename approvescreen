import 'package:flutter/material.dart';
import 'package:graphql_flutter/graphql_flutter.dart';
import 'package:google_fonts/google_fonts.dart';

const String getRequestsQuery = r'''
  query {
    inventoryRequests {
      id
      category
      itemName
      size
      length
      quantity
      description
      status
      createdAt
      requestedBy {
        name
      }
    }
  }
''';

const String approveRequestMutation = r'''
  mutation ApproveRequest($requestId: Int!) {
    approveRequest(requestId: $requestId) {
      success
      message
    }
  }
''';

const String rejectRequestMutation = r'''
  mutation RejectRequest($requestId: Int!) {
    rejectRequest(requestId: $requestId) {
      success
      message
    }
  }
''';

const kGold = Color(0xFFC9A227);
const kBg = Color(0xFF0A0E1A);
const kCard = Color(0xFF1A2035);

class ApproveScreen extends StatefulWidget {
  const ApproveScreen({super.key});

  @override
  State<ApproveScreen> createState() => _ApproveScreenState();
}

class _ApproveScreenState extends State<ApproveScreen> {
  String _selectedTab = 'PENDING';

  final List<Map<String, dynamic>> _tabs = [
    {'label': 'Pending', 'value': 'PENDING', 'color': const Color(0xFFC9A227)},
    {'label': 'Accepted', 'value': 'ACCEPTED', 'color': Colors.green},
    {'label': 'Rejected', 'value': 'REJECTED', 'color': Colors.redAccent},
    {'label': 'All', 'value': 'ALL', 'color': Colors.blueAccent},
  ];

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: kBg,
      appBar: AppBar(
        backgroundColor: kBg,
        elevation: 0,
        iconTheme: const IconThemeData(color: Colors.white),
        title: Text(
          'Approve Requests',
          style: GoogleFonts.outfit(
            color: kGold,
            fontWeight: FontWeight.bold,
            fontSize: 20,
          ),
        ),
      ),
      body: Query(
        options: QueryOptions(
          document: gql(getRequestsQuery),
          fetchPolicy: FetchPolicy.networkOnly,
        ),
        builder: (result, {fetchMore, refetch}) {
          if (result.isLoading) {
            return const Center(
                child: CircularProgressIndicator(color: kGold));
          }

          if (result.hasException) {
            return Center(
              child: Text(result.exception.toString(),
                  style: const TextStyle(color: Colors.red)),
            );
          }

          final List requests = result.data?['inventoryRequests'] ?? [];

          // ✅ Filter based on selected tab
          final filtered = _selectedTab == 'ALL'
              ? requests
              : requests
                  .where((r) =>
                      r['status']?.toString().toUpperCase() == _selectedTab)
                  .toList();

          return Column(
            children: [
              // ✅ Tab Pills
              Container(
                padding:
                    const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
                child: SingleChildScrollView(
                  scrollDirection: Axis.horizontal,
                  child: Row(
                    children: _tabs.map((tab) {
                      final isSelected = _selectedTab == tab['value'];
                      final color = tab['color'] as Color;
                      return GestureDetector(
                        onTap: () =>
                            setState(() => _selectedTab = tab['value']),
                        child: AnimatedContainer(
                          duration: const Duration(milliseconds: 200),
                          margin: const EdgeInsets.only(right: 10),
                          padding: const EdgeInsets.symmetric(
                              horizontal: 20, vertical: 10),
                          decoration: BoxDecoration(
                            color: isSelected
                                ? color
                                : const Color(0xFF1A2035),
                            borderRadius: BorderRadius.circular(30),
                            border: Border.all(
                              color: isSelected
                                  ? color
                                  : Colors.white24,
                            ),
                          ),
                          child: Text(
                            tab['label'],
                            style: GoogleFonts.outfit(
                              color: isSelected
                                  ? (tab['value'] == 'PENDING'
                                      ? Colors.black
                                      : Colors.white)
                                  : Colors.white54,
                              fontWeight: isSelected
                                  ? FontWeight.bold
                                  : FontWeight.normal,
                              fontSize: 13,
                            ),
                          ),
                        ),
                      );
                    }).toList(),
                  ),
                ),
              ),

              // ✅ List
              Expanded(
                child: filtered.isEmpty
                    ? Center(
                        child: Column(
                          mainAxisAlignment: MainAxisAlignment.center,
                          children: [
                            Icon(
                              _selectedTab == 'PENDING'
                                  ? Icons.hourglass_empty
                                  : _selectedTab == 'ACCEPTED'
                                      ? Icons.check_circle_outline
                                      : _selectedTab == 'REJECTED'
                                          ? Icons.cancel_outlined
                                          : Icons.inbox_outlined,
                              color: Colors.white24,
                              size: 48,
                            ),
                            const SizedBox(height: 12),
                            Text(
                              'No ${_tabs.firstWhere((t) => t['value'] == _selectedTab)['label'].toString().toLowerCase()} requests',
                              style: GoogleFonts.outfit(
                                  color: Colors.white38, fontSize: 14),
                            ),
                          ],
                        ),
                      )
                    : ListView.builder(
                        padding: const EdgeInsets.fromLTRB(16, 0, 16, 16),
                        itemCount: filtered.length,
                        itemBuilder: (context, index) {
                          final req = filtered[index];
                          final requestedBy = req['requestedBy'];
                          final userName = requestedBy != null
                              ? requestedBy['name'] ?? 'Unknown'
                              : 'Unknown';

                          final status =
                              req['status']?.toString().toUpperCase() ?? '';
                          final statusColor = status == 'PENDING'
                              ? kGold
                              : status == 'ACCEPTED'
                                  ? Colors.green
                                  : Colors.redAccent;

                          // ✅ Icon per status
                          final statusIcon = status == 'PENDING'
                              ? Icons.hourglass_bottom
                              : status == 'ACCEPTED'
                                  ? Icons.check_circle
                                  : Icons.cancel;

                          return Container(
                            margin: const EdgeInsets.only(bottom: 14),
                            padding: const EdgeInsets.all(16),
                            decoration: BoxDecoration(
                              color: kCard,
                              borderRadius: BorderRadius.circular(16),
                              border: Border.all(
                                  color: statusColor.withOpacity(0.3)),
                            ),
                            child: Column(
                              crossAxisAlignment: CrossAxisAlignment.start,
                              children: [
                                // ✅ Header row with icon
                                Row(
                                  mainAxisAlignment:
                                      MainAxisAlignment.spaceBetween,
                                  children: [
                                    Row(
                                      children: [
                                        Icon(statusIcon,
                                            color: statusColor, size: 20),
                                        const SizedBox(width: 8),
                                        Text(
                                          req['itemName'] ?? '',
                                          style: GoogleFonts.outfit(
                                            color: Colors.white,
                                            fontSize: 16,
                                            fontWeight: FontWeight.bold,
                                          ),
                                        ),
                                      ],
                                    ),
                                    Container(
                                      padding: const EdgeInsets.symmetric(
                                          horizontal: 10, vertical: 4),
                                      decoration: BoxDecoration(
                                        color: statusColor.withOpacity(0.15),
                                        borderRadius:
                                            BorderRadius.circular(20),
                                        border: Border.all(
                                            color:
                                                statusColor.withOpacity(0.4)),
                                      ),
                                      child: Text(
                                        status,
                                        style: GoogleFonts.outfit(
                                          color: statusColor,
                                          fontSize: 11,
                                          fontWeight: FontWeight.bold,
                                        ),
                                      ),
                                    ),
                                  ],
                                ),
                                const SizedBox(height: 10),

                                // ✅ Compact info row
                                Wrap(
                                  spacing: 12,
                                  runSpacing: 4,
                                  children: [
                                    _chipInfo('Category',
                                        req['category'] ?? '-'),
                                    _chipInfo('Size', req['size'] ?? '-'),
                                    _chipInfo(
                                        'Length', req['length'] ?? '-'),
                                    _chipInfo('Qty',
                                        req['quantity'].toString()),
                                  ],
                                ),
                                const SizedBox(height: 6),
                                Text(
                                  'By: $userName',
                                  style: GoogleFonts.outfit(
                                      color: Colors.white54, fontSize: 12),
                                ),
                                if ((req['description'] ?? '').isNotEmpty)
                                  Padding(
                                    padding: const EdgeInsets.only(top: 4),
                                    child: Text(
                                      'Note: ${req['description']}',
                                      style: GoogleFonts.outfit(
                                          color: Colors.white38,
                                          fontSize: 12),
                                    ),
                                  ),

                                // ✅ Buttons only for PENDING
                                if (status == 'PENDING') ...[
                                  const SizedBox(height: 14),
                                  Row(
                                    children: [
                                      Expanded(
                                        child: Mutation(
                                          options: MutationOptions(
                                            document:
                                                gql(approveRequestMutation),
                                            onCompleted: (data) {
                                              ScaffoldMessenger.of(context)
                                                  .showSnackBar(
                                                const SnackBar(
                                                    content: Text(
                                                        'Request approved!')),
                                              );
                                              refetch!();
                                            },
                                            onError: (error) {
                                              ScaffoldMessenger.of(context)
                                                  .showSnackBar(
                                                SnackBar(
                                                    content: Text(
                                                        'Error: ${error.toString()}')),
                                              );
                                            },
                                          ),
                                          builder: (runMutation,
                                              mutationResult) {
                                            return ElevatedButton.icon(
                                              style: ElevatedButton.styleFrom(
                                                backgroundColor: Colors.green,
                                                shape: RoundedRectangleBorder(
                                                    borderRadius:
                                                        BorderRadius.circular(
                                                            10)),
                                                padding:
                                                    const EdgeInsets.symmetric(
                                                        vertical: 12),
                                              ),
                                              onPressed:
                                                  mutationResult?.isLoading ==
                                                          true
                                                      ? null
                                                      : () {
                                                          runMutation({
                                                            'requestId':
                                                                int.parse(req[
                                                                        'id']
                                                                    .toString()),
                                                          });
                                                        },
                                              icon: const Icon(Icons.check,
                                                  color: Colors.white,
                                                  size: 18),
                                              label: Text('Accept',
                                                  style: GoogleFonts.outfit(
                                                      color: Colors.white,
                                                      fontWeight:
                                                          FontWeight.bold)),
                                            );
                                          },
                                        ),
                                      ),
                                      const SizedBox(width: 10),
                                      Expanded(
                                        child: Mutation(
                                          options: MutationOptions(
                                            document:
                                                gql(rejectRequestMutation),
                                            onCompleted: (data) {
                                              ScaffoldMessenger.of(context)
                                                  .showSnackBar(
                                                const SnackBar(
                                                    content: Text(
                                                        'Request rejected.')),
                                              );
                                              refetch!();
                                            },
                                            onError: (error) {
                                              ScaffoldMessenger.of(context)
                                                  .showSnackBar(
                                                SnackBar(
                                                    content: Text(
                                                        'Error: ${error.toString()}')),
                                              );
                                            },
                                          ),
                                          builder: (runMutation,
                                              mutationResult) {
                                            return ElevatedButton.icon(
                                              style: ElevatedButton.styleFrom(
                                                backgroundColor:
                                                    Colors.red.shade900,
                                                shape: RoundedRectangleBorder(
                                                    borderRadius:
                                                        BorderRadius.circular(
                                                            10)),
                                                padding:
                                                    const EdgeInsets.symmetric(
                                                        vertical: 12),
                                              ),
                                              onPressed:
                                                  mutationResult?.isLoading ==
                                                          true
                                                      ? null
                                                      : () {
                                                          runMutation({
                                                            'requestId':
                                                                int.parse(req[
                                                                        'id']
                                                                    .toString()),
                                                          });
                                                        },
                                              icon: const Icon(Icons.close,
                                                  color: Colors.white,
                                                  size: 18),
                                              label: Text('Reject',
                                                  style: GoogleFonts.outfit(
                                                      color: Colors.white,
                                                      fontWeight:
                                                          FontWeight.bold)),
                                            );
                                          },
                                        ),
                                      ),
                                    ],
                                  ),
                                ],
                              ],
                            ),
                          );
                        },
                      ),
              ),
            ],
          );
        },
      ),
    );
  }

  // ✅ Compact chip style info
  Widget _chipInfo(String label, String value) {
    return RichText(
      text: TextSpan(
        children: [
          TextSpan(
            text: '$label: ',
            style: GoogleFonts.outfit(
                color: Colors.white38,
                fontSize: 12),
          ),
          TextSpan(
            text: value,
            style: GoogleFonts.outfit(
                color: Colors.white,
                fontSize: 12,
                fontWeight: FontWeight.bold),
          ),
        ],
      ),
    );
  }

  Widget _infoRow(String label, String value) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 3),
      child: Row(
        children: [
          Text('$label: ',
              style: GoogleFonts.outfit(
                  color: Colors.white54, fontSize: 13)),
          Expanded(
            child: Text(value,
                style: GoogleFonts.outfit(
                    color: Colors.white,
                    fontSize: 13,
                    fontWeight: FontWeight.w600)),
          ),
        ],
      ),
    );
  }
}
