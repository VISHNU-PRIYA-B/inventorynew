import 'package:flutter/material.dart';
import 'package:graphql_flutter/graphql_flutter.dart';

class ResetPasswordScreen extends StatefulWidget {
  final String email;

  const ResetPasswordScreen({super.key, required this.email});

  @override
  State<ResetPasswordScreen> createState() =>
      _ResetPasswordScreenState();
}

class _ResetPasswordScreenState extends State<ResetPasswordScreen> {

  final TextEditingController otpController = TextEditingController();
  final TextEditingController passwordController =
      TextEditingController();

  // ✅ FIX: Password visibility toggle
  bool isPasswordVisible = false;

  final String resetMutation = """
    mutation ResetPassword(\$email: String!, \$otp: String!, \$password: String!) {
      resetPasswordWithOtp(email: \$email, otp: \$otp, password: \$password) {
        success
        message
      }
    }
  """;

  @override
  void dispose() {
    otpController.dispose();
    passwordController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFF0B132B),

      appBar: AppBar(
        backgroundColor: Colors.transparent,
        elevation: 0,
        title: const Text("Reset Password"),
      ),

      body: SingleChildScrollView(
        child: Padding(
          padding: const EdgeInsets.all(20),

          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [

              const SizedBox(height: 30),

              // ✅ EMAIL DISPLAY
              Text(
                "Email: ${widget.email}",
                style: const TextStyle(color: Colors.grey),
              ),

              const SizedBox(height: 30),

              // ✅ OTP FIELD (NO EYE ICON)
              Container(
                decoration: BoxDecoration(
                  color: const Color(0xFF1C2541),
                  borderRadius: BorderRadius.circular(12),
                  border: Border.all(color: Color(0xFFFFD700)),
                ),
                child: TextField(
                  controller: otpController,
                  style: const TextStyle(color: Colors.white),
                  decoration: const InputDecoration(
                    prefixIcon:
                        Icon(Icons.lock_clock, color: Colors.grey),
                    hintText: "Enter OTP",
                    hintStyle: TextStyle(color: Colors.grey),
                    border: InputBorder.none,
                    contentPadding:
                        EdgeInsets.symmetric(vertical: 18),
                  ),
                ),
              ),

              const SizedBox(height: 20),

              // ✅ PASSWORD FIELD WITH EYE ICON
              Container(
                decoration: BoxDecoration(
                  color: const Color(0xFF1C2541),
                  borderRadius: BorderRadius.circular(12),
                  border: Border.all(color: Color(0xFFFFD700)),
                ),
                child: TextField(
                  controller: passwordController,
                  obscureText: !isPasswordVisible,
                  style: const TextStyle(color: Colors.white),
                  decoration: InputDecoration(
                    prefixIcon:
                        const Icon(Icons.lock, color: Colors.grey),
                    hintText: "New Password",
                    hintStyle:
                        const TextStyle(color: Colors.grey),
                    border: InputBorder.none,
                    contentPadding:
                        const EdgeInsets.symmetric(vertical: 18),

                    // 👁 EYE ICON
                    suffixIcon: IconButton(
                      icon: Icon(
                        isPasswordVisible
                            ? Icons.visibility
                            : Icons.visibility_off,
                        color: isPasswordVisible
                            ? Colors.amber
                            : Colors.grey,
                      ),
                      onPressed: () {
                        setState(() {
                          isPasswordVisible =
                              !isPasswordVisible;
                        });
                      },
                    ),
                  ),
                ),
              ),

              const SizedBox(height: 30),

              // ✅ RESET BUTTON WITH GRAPHQL
              Mutation(
                options: MutationOptions(
                  document: gql(resetMutation),

                  onCompleted: (data) {
                    if (!mounted) return;

                    if (data == null) {
                      ScaffoldMessenger.of(context)
                          .showSnackBar(
                        const SnackBar(
                          content:
                              Text("No response from server"),
                        ),
                      );
                      return;
                    }

                    final response =
                        data['resetPasswordWithOtp'];

                    ScaffoldMessenger.of(context)
                        .showSnackBar(
                      SnackBar(
                        content:
                            Text(response['message'] ?? "Done"),
                      ),
                    );

                    if (response['success'] == true) {
                      Navigator.pop(context);
                    }
                  },

                  onError: (error) {
                    if (!mounted) return;

                    print("ERROR: $error");

                    ScaffoldMessenger.of(context)
                        .showSnackBar(
                      const SnackBar(
                        content: Text("Reset failed"),
                      ),
                    );
                  },
                ),

                builder: (runMutation, result) {
                  final isLoading =
                      result?.isLoading ?? false;

                  return GestureDetector(
                    onTap: isLoading
                        ? null
                        : () {
                            final otp =
                                otpController.text.trim();
                            final password =
                                passwordController.text.trim();

                            // ✅ VALIDATION
                            if (otp.isEmpty ||
                                password.isEmpty) {
                              ScaffoldMessenger.of(context)
                                  .showSnackBar(
                                const SnackBar(
                                  content:
                                      Text("Fill all fields"),
                                ),
                              );
                              return;
                            }

                            if (password.length < 6) {
                              ScaffoldMessenger.of(context)
                                  .showSnackBar(
                                const SnackBar(
                                  content: Text(
                                      "Password must be at least 6 characters"),
                                ),
                              );
                              return;
                            }

                            runMutation({
                              "email": widget.email,
                              "otp": otp,
                              "password": password,
                            });
                          },

                    child: Container(
                      width: double.infinity,
                      height: 55,
                      decoration: BoxDecoration(
                        borderRadius:
                            BorderRadius.circular(12),
                        gradient: const LinearGradient(
                          colors: [
                            Color(0xFFBFA76A),
                            Color(0xFFFFD700),
                          ],
                        ),
                      ),

                      child: Center(
                        child: isLoading
                            ? const CircularProgressIndicator(
                                color: Colors.black,
                              )
                            : const Text(
                                "Reset Password",
                                style: TextStyle(
                                  color: Colors.black,
                                  fontWeight:
                                      FontWeight.bold,
                                  fontSize: 16,
                                ),
                              ),
                      ),
                    ),
                  );
                },
              ),
            ],
          ),
        ),
      ),
    );
  }
}
